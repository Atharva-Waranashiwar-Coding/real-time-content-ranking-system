# Database Configuration
DB_USER=rankinguser
DB_PASSWORD=rankingpass
DB_NAME=ranking_db
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
DEMO_REFERENCE_TIME=2026-04-08T14:00:00+00:00
RANKING_FIXED_NOW=2026-04-08T14:00:00+00:00

# Resilience Configuration
HTTP_CLIENT_RETRY_MAX_ATTEMPTS=3
HTTP_CLIENT_RETRY_INITIAL_DELAY_SECONDS=0.1
HTTP_CLIENT_RETRY_MAX_DELAY_SECONDS=1.0
HTTP_CLIENT_RETRY_BACKOFF_MULTIPLIER=2.0
KAFKA_PUBLISH_RETRY_MAX_ATTEMPTS=3
KAFKA_PUBLISH_RETRY_INITIAL_DELAY_SECONDS=0.1
KAFKA_PUBLISH_RETRY_MAX_DELAY_SECONDS=1.0
KAFKA_PUBLISH_RETRY_BACKOFF_MULTIPLIER=2.0
PROCESSOR_MAX_PROCESSING_ATTEMPTS=3
KAFKA_DLQ_TOPIC=interactions.events.dlq.v1
